  <script>
    (function() {
        const m3uUrl = "https://m3u.work/NliMw2dI.m3u";
        const video = document.getElementById('video');
        const channelNameDiv = document.getElementById('channel-name');
        const fsBtn = document.getElementById('fs-btn');
        const channelsToggle = document.getElementById('channels-toggle');
        const sidebar = document.getElementById('sidebar');
        const groupTabs = document.getElementById('groupTabs');
        const channelList = document.getElementById('channelList'); // değişti
        const controlOverlay = document.getElementById('controlOverlay');
        const currentTimeSpan = document.getElementById('currentTime');
        const durationSpan = document.getElementById('durationTime');
        const progressTrack = document.getElementById('progressTrack');
        const progressFill = document.getElementById('progressFill');
        const seekBack = document.getElementById('seekBackBtn');
        const seekFwd = document.getElementById('seekFwdBtn');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        let playlist = [];
        let groups = [];
        let currentTrack = 0;
        let currentGroup = null;
        let hls = null;
        let idleTimer;

        function showUI() {
            document.body.classList.remove('hide-cursor');
            controlOverlay.classList.add('visible');
            channelsToggle.classList.remove('hidden');
            clearTimeout(idleTimer);
            idleTimer = setTimeout(() => {
                if (!sidebar.classList.contains('open')) {
                    document.body.classList.add('hide-cursor');
                    controlOverlay.classList.remove('visible');
                    channelsToggle.classList.add('hidden');
                }
            }, 10000);
        }

        function handleUserActivity() {
            showUI();
        }

        ['mousemove', 'touchstart', 'keydown', 'click'].forEach(ev => {
            document.addEventListener(ev, handleUserActivity, { passive: true });
        });

        function handleSidebarChange() {
            if (sidebar.classList.contains('open')) {
                clearTimeout(idleTimer);
                controlOverlay.classList.add('visible');
                channelsToggle.classList.remove('hidden');
            } else {
                showUI();
            }
        }

        const observer = new MutationObserver(handleSidebarChange);
        observer.observe(sidebar, { attributes: true, attributeFilter: ['class'] });

        fetch(m3uUrl).then(r => r.text()).then(data => {
            const lines = data.split('\n');
            let currentName = '';
            let currentGroupTitle = 'Genel';
            for (let i = 0; i < lines.length; i++) {
                let line = lines[i].trim();
                if (line.startsWith('#EXTINF:')) {
                    const groupMatch = line.match(/group-title="([^"]+)"/i);
                    if (groupMatch) currentGroupTitle = groupMatch[1] || 'Genel';
                    else currentGroupTitle = 'Genel';
                    let namePart = line.split(',').pop().trim();
                    if (namePart) currentName = namePart;
                } else if (line.startsWith('http')) {
                    if (!currentName) currentName = 'İsimsiz';
                    playlist.push({ url: line, name: currentName, group: currentGroupTitle });
                    currentName = ''; currentGroupTitle = 'Genel';
                }
            }
            const groupSet = new Set(playlist.map(p => p.group));
            groups = Array.from(groupSet).sort();
            if (groups.length === 0) groups = ['Genel'];

            if (playlist.length > 0) {
                const savedTrack = localStorage.getItem("vood_last_track");
                if (savedTrack && playlist[savedTrack]) currentTrack = parseInt(savedTrack);
                else currentTrack = 0;
                currentGroup = playlist[currentTrack].group;

                renderGroupTabs();
                renderChannelList(currentGroup); // değişti
                loadSource(playlist[currentTrack]);
            } else {
                channelNameDiv.innerText = "Yayın Yok";
            }
        }).catch(e => console.log("m3u hatası", e));

        function renderGroupTabs() {
            groupTabs.innerHTML = '';
            groups.forEach(group => {
                const tab = document.createElement('span');
                tab.className = `group-tab ${group === currentGroup ? 'active' : ''}`;
                tab.innerText = group;
                tab.setAttribute('tabindex', '0');
                tab.dataset.group = group;
                tab.addEventListener('click', (e) => {
                    currentGroup = group;
                    document.querySelectorAll('.group-tab').forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    renderChannelList(group); // değişti
                    handleUserActivity();
                });
                tab.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') tab.click(); });
                groupTabs.appendChild(tab);
            });
        }

        // Kanal listesini dikey şerit olarak oluştur
        function renderChannelList(groupName) {
            channelList.innerHTML = '';
            const filtered = playlist.filter(p => p.group === groupName);
            filtered.forEach((item) => {
                const globalIndex = playlist.findIndex(p => p.url === item.url && p.name === item.name);
                const div = document.createElement('div');
                div.className = `channel-item ${globalIndex === currentTrack ? 'active' : ''}`;
                div.innerText = item.name;
                div.dataset.index = globalIndex;
                div.setAttribute('tabindex', '0');
                div.addEventListener('click', (e) => {
                    const idx = parseInt(e.currentTarget.dataset.index);
                    if (!isNaN(idx) && playlist[idx]) {
                        currentTrack = idx;
                        currentGroup = playlist[idx].group;
                        localStorage.setItem("vood_last_track", currentTrack);
                        loadSource(playlist[currentTrack]);
                        sidebar.classList.remove('open');
                        // sekmeleri ve listeyi güncelle
                        renderGroupTabs();
                        renderChannelList(currentGroup);
                        handleUserActivity();
                    }
                });
                div.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') div.click(); });
                channelList.appendChild(div);
            });
        }

        function loadSource(track) {
            channelNameDiv.innerText = track.name;
            if (hls) hls.destroy();
            if (Hls.isSupported()) {
                hls = new Hls();
                hls.loadSource(track.url);
                hls.attachMedia(video);
                hls.on(Hls.Events.MANIFEST_PARSED, () => {
                    const lastPos = localStorage.getItem("vood_last_position");
                    const lastTrack = localStorage.getItem("vood_last_track");
                    if (lastPos && lastTrack && parseInt(lastTrack) === currentTrack) {
                        video.currentTime = parseFloat(lastPos);
                    }
                    video.play().catch(e => console.log);
                    handleUserActivity();
                });
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                video.src = track.url;
                video.play();
            }
            // sekmeleri ve listeyi güncelle (aktif kanal vurgusu için)
            renderGroupTabs();
            renderChannelList(track.group);
        }

        video.addEventListener('ended', () => {
            if (playlist.length === 0) return;
            currentTrack = (currentTrack + 1) % playlist.length;
            localStorage.setItem("vood_last_track", currentTrack);
            localStorage.setItem("vood_last_position", 0);
            loadSource(playlist[currentTrack]);
        });

        video.addEventListener('timeupdate', () => {
            if (!playlist.length) return;
            const current = video.currentTime || 0;
            const duration = video.duration || 0;
            if (duration) progressFill.style.width = (current / duration) * 100 + '%';
            currentTimeSpan.innerText = formatTime(current);
            durationSpan.innerText = formatTime(duration);
            if (Math.floor(current) % 2 === 0) {
                localStorage.setItem("vood_last_position", current);
            }
        });

        video.addEventListener('loadedmetadata', () => {
            durationSpan.innerText = formatTime(video.duration || 0);
        });

        function formatTime(sec) {
            if (isNaN(sec) || sec === Infinity) return '00:00';
            const h = Math.floor(sec / 3600);
            const m = Math.floor((sec % 3600) / 60);
            const s = Math.floor(sec % 60);
            if (h > 0) return `${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
            return `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }

        progressTrack.addEventListener('click', (e) => {
            const rect = progressTrack.getBoundingClientRect();
            const pos = (e.clientX - rect.left) / rect.width;
            video.currentTime = pos * video.duration;
            handleUserActivity();
        });

        seekBack.addEventListener('click', () => { video.currentTime = Math.max(0, video.currentTime - 10); handleUserActivity(); });
        seekFwd.addEventListener('click', () => { video.currentTime = Math.min(video.duration, video.currentTime + 10); handleUserActivity(); });
        prevBtn.addEventListener('click', () => {
            if (playlist.length === 0) return;
            currentTrack = (currentTrack - 1 + playlist.length) % playlist.length;
            localStorage.setItem("vood_last_track", currentTrack);
            loadSource(playlist[currentTrack]); handleUserActivity();
        });
        nextBtn.addEventListener('click', () => {
            if (playlist.length === 0) return;
            currentTrack = (currentTrack + 1) % playlist.length;
            localStorage.setItem("vood_last_track", currentTrack);
            loadSource(playlist[currentTrack]); handleUserActivity();
        });

        fsBtn.addEventListener('click', toggleFullScreen);
        function toggleFullScreen() {
            const wrapper = document.getElementById('player-wrapper');
            if (!document.fullscreenElement) {
                if (wrapper.requestFullscreen) wrapper.requestFullscreen();
                else if (wrapper.webkitRequestFullscreen) wrapper.webkitRequestFullscreen();
            } else {
                if (document.exitFullscreen) document.exitFullscreen();
            }
            handleUserActivity();
        }

        channelsToggle.addEventListener('click', () => {
            sidebar.classList.add('open');
            handleUserActivity();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                handleUserActivity();
            }
        });

        sidebar.addEventListener('mousemove', (e) => e.stopPropagation());
        sidebar.addEventListener('touchstart', (e) => e.stopPropagation());

        handleUserActivity();
        document.addEventListener('fullscreenchange', () => handleUserActivity());
    })();
</script> 
